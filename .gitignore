# Secrets — never commit
.env
.env.local
**/.env
!**/.env.example
LOCAL_DEV_CREDENTIALS.txt
*CREDENTIALS*.txt

# Python
__pycache__/
*.py[cod]
*.sqlite3
.venv/
venv/

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo

# Large local uploads (keep folder via Backend .gitignore + .gitkeep)
Backend/data/uploads/*
!Backend/data/uploads/.gitkeep

# Django user uploads (admin attachments, etc.)
Backend/media/

# Collected static (build output; do not commit)
Backend/staticfiles/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
