# Optional: Django Syndicate API (default is http://127.0.0.1:8000/api)
NEXT_PUBLIC_SYNDICATE_API_URL=http://127.0.0.1:8000/api
#
# Local login/signup: run Django in another terminal, from Backend:
#   python manage.py migrate
#   python manage.py runserver 0.0.0.0:8000
# Then open the dashboard (e.g. npm run dev). "Failed to fetch" = API not reachable or wrong URL.

# Railway: backend public URL must include https:// and end with /api, e.g.:
# NEXT_PUBLIC_SYNDICATE_API_URL=https://your-django-service.up.railway.app/api
# Wrong: hostname only, or missing /api — signup/login fetch will fail.
# Wrong: same hostname as the Next.js frontend — /static/admin/* will 404 (Django is another service).
#
# Optional (runtime; no client bundle): proxy /static/* from the frontend to Django (fixes admin CSS on the frontend host).
# SYNDICATE_DJANGO_ORIGIN=https://your-django-service.up.railway.app
#
# Railway + Dockerfile: enable this variable for the BUILD phase (not only runtime),
# or the client bundle will keep localhost and show "Failed to fetch" on HTTPS.
