# Copy to .env in this folder (Backend/). Django loads it automatically.

# Optional production secret (dev default exists in settings.py)
# DJANGO_SECRET_KEY=change-me-in-production

# Local: true | Railway: false (or omit; RAILWAY_ENVIRONMENT defaults debug off)
# DJANGO_DEBUG=true

# Default password for seed_portal / demo users (demo, viewer1, admin1)
PORTAL_DEV_PASSWORD=SyndicateDev2026!

# When true, seed_portal resets passwords for demo, viewer1, admin1 every run
# PORTAL_ALWAYS_RESET_PASSWORDS=1

# Comma-separated extra CORS origins (LAN IP, another port, etc.)
# CORS_EXTRA_ORIGINS=http://192.168.1.5:3000,http://localhost:3001

# Comma-separated ALLOWED_HOSTS additions (also set RAILWAY_PUBLIC_DOMAIN on Railway)
# DJANGO_ALLOWED_HOSTS=192.168.1.5,testserver

# OpenAI (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Membership hub: allow GET /api/portal/membership/* without JWT (default follows DEBUG).
# MEMBERSHIP_ALLOW_ANONYMOUS_READ=false

# --- PostgreSQL (Railway) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# PGHOST=... PGPORT=5432 PGUSER=... PGPASSWORD=... PGDATABASE=...
# DATABASE_SSL_REQUIRE=true

# Optional: max in-memory multipart size in MB (admin/API uploads). Default 32.
# DATA_UPLOAD_MAX_MB=32

# Django admin (optional — ensure_superuser runs on deploy via railway_start.sh)
# DJANGO_SUPERUSER_EMAIL=you@example.com
# DJANGO_SUPERUSER_PASSWORD=use-a-long-random-secret
# DJANGO_SUPERUSER_NO_PASSWORD_SYNC=1

# Cloudinary (uploads / FileField)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Object storage (S3-compatible: Railway Bucket, R2, etc.) ---
# AWS_S3_ENDPOINT_URL=https://storage.railway.app
# AWS_STORAGE_BUCKET_NAME=...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# PRESIGNED_URL_EXPIRE_SECONDS=3600

# API: GET /api/documents/<id>/download-url/?expires_in=3600
