# VdoCipher (secure video — uploads never hit Django disk)
# Get API secret from VdoCipher dashboard → API keys
VDO_API_SECRET=
# Default: https://dev.vdocipher.com/api (use https://www.vdocipher.com/api for production if required by your account)
VDO_BASE_URL=https://dev.vdocipher.com/api
# OTP validity in seconds (60–86400)
VDO_OTP_TTL=300
